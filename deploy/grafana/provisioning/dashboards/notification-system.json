{
  "uid": "nsys-overview",
  "title": "Notification System",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview",
